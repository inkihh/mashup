ANTHROPIC_API_KEY=sk-ant-...

# AI provider: "anthropic" (default) or "deepseek"
# AI_PROVIDER=anthropic

# DeepSeek settings (only needed if AI_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Effects toggles (all enabled by default)
# EFFECT_HIGH_PASS=true
# EFFECT_LOW_PASS=true
# EFFECT_REVERB=true
# EFFECT_DELAY=true
# EFFECT_COMPRESSOR=true
